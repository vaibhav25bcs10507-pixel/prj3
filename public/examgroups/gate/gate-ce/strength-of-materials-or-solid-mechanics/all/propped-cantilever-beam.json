        "identifier": "A",
        "content": " $\\frac{3 M}{2 L}-\\frac{6 E I \\Delta}{L^3}$\n"
      },
      {
        "identifier": "B",
        "content": "$\\frac{8 M}{3 L}-\\frac{2 E I \\Delta}{L^3}$\n"
      },
      {
        "identifier": "C",
        "content": "$\\frac{3 M}{2 L}-\\frac{3 E I \\Delta}{L^3}$\n"
