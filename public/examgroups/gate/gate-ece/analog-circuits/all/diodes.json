        "identifier": "C",
        "content": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1lywnpqcf/b679749b-4d66-469e-b955-6401b9d5bec9/cb2c2a00-47fa-11ef-a4ec-23a9bd42cec6/file-jaoe38c1lywnpqcg.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1lywnpqcf/b679749b-4d66-469e-b955-6401b9d5bec9/cb2c2a00-47fa-11ef-a4ec-23a9bd42cec6/file-jaoe38c1lywnpqcg.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"GATE ECE 2023 Analog Circuits - Diodes Question 5 English Option 3\">"
      },
      {
        "identifier": "D",
        "content": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1lywnplk7/2bc5956f-f0ae-42d4-9a2a-c96c6a500e95/c779f770-47fa-11ef-a4ec-23a9bd42cec6/file-jaoe38c1lywnplk8.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1lywnplk7/2bc5956f-f0ae-42d4-9a2a-c96c6a500e95/c779f770-47fa-11ef-a4ec-23a9bd42cec6/file-jaoe38c1lywnplk8.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"GATE ECE 2023 Analog Circuits - Diodes Question 5 English Option 4\">"
      }
