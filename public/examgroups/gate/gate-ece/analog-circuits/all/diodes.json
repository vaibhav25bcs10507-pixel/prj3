      },
      {
        "identifier": "B",
        "content": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1lywnpv1m/61132dc4-2303-486b-957e-86267b6857ec/cecd6ca0-47fa-11ef-a4ec-23a9bd42cec6/file-jaoe38c1lywnpv1n.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1lywnpv1m/61132dc4-2303-486b-957e-86267b6857ec/cecd6ca0-47fa-11ef-a4ec-23a9bd42cec6/file-jaoe38c1lywnpv1n.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"GATE ECE 2023 Analog Circuits - Diodes Question 5 English Option 2\">"
      },
