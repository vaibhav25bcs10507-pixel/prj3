        "content": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1mbezdkft/0173fe86-4cee-4a43-a149-9277a32c264b/1aafaa90-3fa1-11f0-a491-e768f614f5b9/file-jaoe38c1mbezdkfu.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1mbezdkft/0173fe86-4cee-4a43-a149-9277a32c264b/1aafaa90-3fa1-11f0-a491-e768f614f5b9/file-jaoe38c1mbezdkfu.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"GATE ECE 2025 Control Systems - Signal Flow Graph and Block Diagram Question 2 English Option 2\">"
      },
      {
        "identifier": "C",
        "content": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1mbezg6b5/30d453d3-a86c-4a73-ae4d-1ed257495230/6332e610-3fa1-11f0-a491-e768f614f5b9/file-jaoe38c1mbezg6b6.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1mbezg6b5/30d453d3-a86c-4a73-ae4d-1ed257495230/6332e610-3fa1-11f0-a491-e768f614f5b9/file-jaoe38c1mbezg6b6.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"GATE ECE 2025 Control Systems - Signal Flow Graph and Block Diagram Question 2 English Option 3\">"
      },
      {
        "identifier": "D",
        "content": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1mbezghu1/77358380-ef63-4e07-865e-27786c60fb16/6c19f390-3fa1-11f0-a491-e768f614f5b9/file-jaoe38c1mbezghu2.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1mbezghu1/77358380-ef63-4e07-865e-27786c60fb16/6c19f390-3fa1-11f0-a491-e768f614f5b9/file-jaoe38c1mbezghu2.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"GATE ECE 2025 Control Systems - Signal Flow Graph and Block Diagram Question 2 English Option 4\">"
      }
