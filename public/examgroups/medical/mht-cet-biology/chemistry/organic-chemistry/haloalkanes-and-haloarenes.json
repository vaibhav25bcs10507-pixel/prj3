    ],
    "answer": null,
    "explanation": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1mfo8ns26/d831bab5-29c4-438b-acdc-eb313ef02955/54352f00-93e9-11f0-a2b3-1fa2d7fb2438/file-jaoe38c1mfo8ns34.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1mfo8ns26/d831bab5-29c4-438b-acdc-eb313ef02955/54352f00-93e9-11f0-a2b3-1fa2d7fb2438/file-jaoe38c1mfo8ns34.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"MHT CET (PCB) 2025 9th April Evening Shift Chemistry - Haloalkanes and Haloarenes Question 2 English Explanation\">",
