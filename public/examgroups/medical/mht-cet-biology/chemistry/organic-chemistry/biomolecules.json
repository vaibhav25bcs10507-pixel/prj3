  {
    "comprehension": null,
    "direction": null,
    "content": "<p>Which from following amino acids is synthesized in our body?</p>",
    "options": [
      {
        "identifier": "A",
        "content": "<p>Proline</p>\n"
      },
      {
        "identifier": "B",
        "content": "<p>Phenylalanine</p>\n"
      },
      {
        "identifier": "C",
        "content": "<p>Methionine</p>\n"
      },
      {
        "identifier": "D",
        "content": "<p>Valine</p>"
      }
    ],
    "correct_options": [
      "A"
    ],
    "answer": null,
    "explanation": "<p>The correct answer is:  </p>\n<p>✅ <strong>Option A: Proline</strong>  </p>\n<h3>Explanation:</h3>\n<p>Amino acids are classified as <strong>essential</strong> or <strong>non-essential</strong> based on whether the human body can synthesize them.</p>\n<ul>\n<li><p><strong>Essential amino acids</strong>: Cannot be synthesized by the body and must be obtained from the diet.  </p>\n<p>→ Examples: Phenylalanine, Methionine, Valine, etc.</p></li>\n<li><p><strong>Non-essential amino acids</strong>: Can be synthesized by the body.  </p>\n<p>→ Example: Proline (synthesized from glutamate).</p></li>\n</ul>\n<h3>Therefore:</h3>\n<ul>\n<li><p><strong>Proline</strong> → Non-essential (synthesized in the body)  </p></li>\n<li><p><strong>Phenylalanine</strong> → Essential  </p></li>\n<li><p><strong>Methionine</strong> → Essential  </p></li>\n<li><p><strong>Valine</strong> → Essential  </p></li>\n</ul>\n<p>✅ <strong>Final Answer: Proline</strong></p>",
    "topic": null,
    "year": 2025,
    "yearKey": "mht-cet-pcb-2025-9th-april-morning-shift",
    "difficulty": null
  },
