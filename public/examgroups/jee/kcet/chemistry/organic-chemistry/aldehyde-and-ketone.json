    "content": "<p>Arrange the following compounds in their decreasing order of reactivity towards Nucleop addition reaction.</p>\n<p>$$ \\mathrm{CH}_3 \\mathrm{COCH}_3, \\mathrm{CH}_3 \\mathrm{COC}_2 \\mathrm{H}_5, \\mathrm{CH}_3 \\mathrm{CHO} $$</p>",
    "options": [
      {
        "identifier": "A",
        "content": "$\\mathrm{CH}_3 \\mathrm{CHO}>\\mathrm{CH}_3 \\mathrm{COCH}_3>\\mathrm{CH}_3 \\mathrm{COC}_2 \\mathrm{H}_5$\n"
      },
      {
        "identifier": "B",
        "content": "$\\mathrm{CH}_3 \\mathrm{COCH}_3>\\mathrm{CH}_3 \\mathrm{CHO}>\\mathrm{CH}_3 \\mathrm{COC}_2 \\mathrm{H}_5$\n"
      },
      {
        "identifier": "C",
        "content": " $\\mathrm{CH}_3 \\mathrm{COC}_2 \\mathrm{H}_5>\\mathrm{CH}_3 \\mathrm{COCH}_3>\\mathrm{CH}_3 \\mathrm{CHO}$\n"
