    "comprehension": null,
    "direction": null,
    "content": "<p>A haloalkane undergoes $\\mathrm{S}_{\\mathrm{N}} 2$ or $\\mathrm{S}_{\\mathrm{N}} 1$ reaction depending on</p>",
    "options": [
      {
        "identifier": "A",
        "content": " solvent used in the reaction\n"
      },
      {
        "identifier": "B",
        "content": " low temperature\n"
      },
      {
        "identifier": "C",
        "content": " the type of halogen atom\n"
      },
      {
        "identifier": "D",
        "content": " stability of the haloalkane"
      }
    ],
    "correct_options": [
      "A"
    ],
    "answer": null,
    "explanation": "<p>$\\bullet$ Haloalkanes undergoing $\\mathrm{S}_{\\mathrm{N}} 2$ or $\\mathrm{S}_{\\mathrm{N}} 1$ reaction depends upon the solvent used in the reaction.</p>\n<p>$\\bullet$ $\\mathrm{S}_{\\mathrm{N}} 2$ reactions are generally carried out in polar aprotic solvent while $\\mathrm{S}_{\\mathrm{N}} 1$ reactions are carried out in polar protic solvents.</p>",
    "topic": null,
    "year": 2024,
    "yearKey": "kcet-2024",
    "difficulty": null
  },
