  {
    "comprehension": null,
    "direction": null,
    "content": "<p>A polymer sample contains 3 molecules of molar mass $10^3, 3$ molecules of molar mass 500 and 4 molecules of molar mass 200 . What is it's weight average molecular mass?</p>\n",
    "options": [
      {
        "identifier": "A",
        "content": "<p>530</p>\n"
      },
      {
        "identifier": "B",
        "content": "<p>737.7</p>\n"
      },
      {
        "identifier": "C",
        "content": "<p>834.4</p>\n"
      },
      {
        "identifier": "D",
        "content": "<p>821.6</p>"
      }
    ],
    "correct_options": [
      "B"
    ],
    "answer": null,
    "explanation": "<p>$$ \\begin{aligned} &\\text { Weight average molecular mass }\\\\ &\\begin{aligned} & \\left(\\bar{M}_w\\right)=\\frac{\\Sigma n_i m_i^2}{\\Sigma n_i m_i} \\\\ & =\\frac{3 \\times\\left(10^3\\right)^2+3 \\times(500)^2+4 \\times(200)^2}{3 \\times 10^3+3 \\times 500+4 \\times 200} \\\\ & =\\frac{3,000,000+7,50,000+1,60,000}{5300} \\\\ & =737.7 \\end{aligned} \\end{aligned} $$</p>",
    "topic": null,
    "year": 2023,
    "yearKey": "ts-eamcet-2023-online-13th-may-morning-shift",
    "difficulty": null
  },
  {
    "comprehension": null,
    "direction": null,
    "content": "<p>$$ \\text { Match the following } $$</p>\n<style type=\"text/css\">\n\n.tg  {border-collapse:collapse;border-spacing:0;}\n\n.tg td{border-color:black;border-style:solid;border-width:1px;font-family:Arial, sans-serif;font-size:14px;\n\n  overflow:hidden;padding:10px 5px;word-break:normal;}\n\n.tg th{border-color:black;border-style:solid;border-width:1px;font-family:Arial, sans-serif;font-size:14px;\n\n  font-weight:normal;overflow:hidden;padding:10px 5px;word-break:normal;}\n\n.tg .tg-c3ow{border-color:inherit;text-align:center;vertical-align:top}\n\n</style>\n<table class=\"tg\"><thead>\n\n  <tr>\n\n    <th class=\"tg-c3ow\" colspan=\"2\">List-I<br>(Polymer)</th>\n\n    <th class=\"tg-c3ow\" colspan=\"2\">List-II<br>(Monomers)</th>\n\n  </tr></thead>\n\n<tbody>\n\n  <tr>\n\n    <td class=\"tg-c3ow\">(A)</td>\n\n    <td class=\"tg-c3ow\">Bakelite<br></td>\n\n    <td class=\"tg-c3ow\">(I)</td>\n\n    <td class=\"tg-c3ow\">$$<br>\\text { 2-methvl-1, 3-butadiene }<br>$$</td>\n\n  </tr>\n\n  <tr>\n\n    <td class=\"tg-c3ow\">(B)</td>\n\n    <td class=\"tg-c3ow\">Natural rubber</td>\n\n    <td class=\"tg-c3ow\">(II)</td>\n\n    <td class=\"tg-c3ow\">$$<br>\\text { Glvcine + aminocaproic acid }<br>$$<br></td>\n\n  </tr>\n\n  <tr>\n\n    <td class=\"tg-c3ow\">(C)</td>\n\n    <td class=\"tg-c3ow\">Glyptal</td>\n\n    <td class=\"tg-c3ow\">(III)</td>\n\n    <td class=\"tg-c3ow\">$$<br>\\text { Phenol + formaldehyde }<br>$$<br></td>\n\n  </tr>\n\n  <tr>\n\n    <td class=\"tg-c3ow\">(D)</td>\n\n    <td class=\"tg-c3ow\">Nylon 2-nylon 6</td>\n\n    <td class=\"tg-c3ow\">(IV)</td>\n\n    <td class=\"tg-c3ow\">$$<br>\\text { Phthalic acid + ethylene glycol }<br>$$<br></td>\n\n  </tr>\n\n</tbody>\n\n</table>",
    "options": [
      {
        "identifier": "A",
        "content": "A-IV, B-I, C-II, D-III\n"
      },
      {
        "identifier": "B",
        "content": "A-III, B-I, C-IV, D-II\n"
      },
      {
        "identifier": "C",
        "content": "A-III, B-II, C-IV, D-I\n"
      },
      {
