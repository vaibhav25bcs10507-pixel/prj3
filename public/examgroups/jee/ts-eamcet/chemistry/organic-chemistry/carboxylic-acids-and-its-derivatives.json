    "comprehension": null,
    "direction": null,
    "content": "<p>The reagent that can reduce the carboxylic acid group to the corresponding alcohol is</p>\n",
    "options": [
      {
        "identifier": "A",
        "content": "<p>$\\mathrm{NaBH}_4 / \\mathrm{H}_3 \\mathrm{O}^{+}$</p>\n"
      },
      {
        "identifier": "B",
        "content": "<p>$\\mathrm{B}_2 \\mathrm{H}_6 / \\mathrm{H}_3 \\mathrm{O}^{+}$</p>\n"
      },
      {
        "identifier": "C",
        "content": "<p>$\\mathrm{Zn}-\\mathrm{Hg} /$ conc. HCl</p>\n"
