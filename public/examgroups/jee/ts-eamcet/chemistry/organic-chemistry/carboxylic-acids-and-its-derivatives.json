      },
      {
        "identifier": "C",
        "content": "<p>$-\\mathrm{COOH},-\\mathrm{NO}_2$</p>\n"
      },
      {
        "identifier": "D",
        "content": "<p>$-\\mathrm{SO}_3 \\mathrm{H}_1-\\mathrm{NO}_2$</p>"
      }
    ],
