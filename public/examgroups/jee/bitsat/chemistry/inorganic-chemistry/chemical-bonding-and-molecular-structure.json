    "content": "<p>The central atom shows $d$-orbital participation in hybridisation in</p>\n",
    "options": [
      {
        "identifier": "A",
        "content": "<p>$\\mathrm{XeF}_2$</p>\n"
      },
      {
        "identifier": "B",
        "content": "<p>$\\mathrm{SO}_2$</p>\n"
      },
      {
        "identifier": "C",
