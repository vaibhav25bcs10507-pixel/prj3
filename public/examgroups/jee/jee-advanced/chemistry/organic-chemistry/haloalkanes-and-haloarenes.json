    "explanation": "<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1liw8qizc/fdb78d03-9dd0-4194-be4c-5de684d3011f/c24b1180-0afc-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8qizd.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1liw8qizc/fdb78d03-9dd0-4194-be4c-5de684d3011f/c24b1180-0afc-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8qizd.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0px auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Advanced 2023 Paper 2 Online Chemistry - Haloalkanes and Haloarenes Question 2 English Explanation 1\">\n<br><img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1liw8qfsd/6c1bb8c7-2376-4fc7-a9cd-4deffee4ce4c/bfd381d0-0afc-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8qfse.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1liw8qfsd/6c1bb8c7-2376-4fc7-a9cd-4deffee4ce4c/bfd381d0-0afc-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8qfse.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0px auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Advanced 2023 Paper 2 Online Chemistry - Haloalkanes and Haloarenes Question 2 English Explanation 2\">\n<br><img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1liw8stxt/1062e613-4deb-472f-9820-1222f93e38f0/02604010-0afd-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8stxu.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1liw8stxt/1062e613-4deb-472f-9820-1222f93e38f0/02604010-0afd-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8stxu.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0px auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Advanced 2023 Paper 2 Online Chemistry - Haloalkanes and Haloarenes Question 2 English Explanation 3\">\n<br><img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/6y3zli1liw8sq5f/4512bfff-51ba-4665-a674-b0121df4b6c8/ff730b30-0afc-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8sq5g.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/6y3zli1liw8sq5f/4512bfff-51ba-4665-a674-b0121df4b6c8/ff730b30-0afc-11ee-8e6d-ed93ab6ac878/file-6y3zli1liw8sq5g.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0px auto;max-height:40vh;vertical-align:baseline\" alt=\"JEE Advanced 2023 Paper 2 Online Chemistry - Haloalkanes and Haloarenes Question 2 English Explanation 4\">",
