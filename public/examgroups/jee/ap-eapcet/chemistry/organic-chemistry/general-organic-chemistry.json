  {
    "comprehension": null,
    "direction": null,
    "content": "Arrange the following in decreasing order of their basicity.\n<img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/jaoe38c1m8qadrbv/46094520-068b-4f6d-bed9-8f637fdf4273/1d6fb6b0-0a74-11f0-93a1-adbaa87ebf49/file-jaoe38c1m8qadrbw.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/jaoe38c1m8qadrbv/46094520-068b-4f6d-bed9-8f637fdf4273/1d6fb6b0-0a74-11f0-93a1-adbaa87ebf49/file-jaoe38c1m8qadrbw.png\" loading=\"lazy\" style=\"max-width:100%;height:auto;display:block;margin:0 auto;max-height:40vh;vertical-align:baseline\" alt=\"AP EAPCET 2024 - 21th May Morning Shift Chemistry - General Organic Chemistry Question 7 English\">",
    "options": [
      {
        "identifier": "A",
