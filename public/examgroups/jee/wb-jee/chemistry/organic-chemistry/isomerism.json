    ],
    "answer": null,
    "explanation": "<p>Monobromination of n-butane in form of free radical take place as follows:</p>\n<p><img src=\"https://app-content.cdn.examgoal.net/fly/@width/image/1ldb1yw6s/e86a41e6-36b4-4e6f-8aec-f4083681f04a/c0885a50-9c58-11ed-9319-f1181e85fdb4/file-1ldb1yw6t.png?format=png\" data-orsrc=\"https://app-content.cdn.examgoal.net/image/1ldb1yw6s/e86a41e6-36b4-4e6f-8aec-f4083681f04a/c0885a50-9c58-11ed-9319-f1181e85fdb4/file-1ldb1yw6t.png\" loading=\"lazy\" style=\"max-width: 100%;height: auto;display: block;margin: 0 auto;max-height: 50vh\" alt=\"WB JEE 2022 Chemistry - Isomerism Question 6 English Explanation\"></p>\n<p>$$\\therefore$$ Total product = 3</p>",
    "topic": null,
    "year": 2022,
    "yearKey": "wb-jee-2022",
    "difficulty": null
  },
